            <div style="text-align:center;padding:80px 20px;">
                <p style="color:var(--text-secondary);margin-bottom:20px;">未找到该作品</p>
                <button class="btn btn-primary" onclick="navigateTo('works')">返回作品列表</button>
            </div>`;
        return;
    }

    const tags = (work.tags || []).map(t => `<span class="work-detail-tag">${escHtml(t)}</span>`).join('');
    const statusClass = work.status === '已发布' || work.status === '已更新' ? 'success' : 'info';
    const coverHtml = work.cover ? `<img src="${escHtml(work.cover)}" alt="${escHtml(work.title)}" class="work-detail-cover">` : '';

    main.innerHTML = `
        <div class="work-detail">
            <div class="work-detail-header">
                <div class="work-detail-back" onclick="navigateTo('works')">
                    <i class="fas fa-arrow-left"></i> 返回作品列表
