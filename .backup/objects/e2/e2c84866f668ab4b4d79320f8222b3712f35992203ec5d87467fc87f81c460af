                        ${workOpts}
                    </select>
                </div>
                <div class="form-group">
                    <label for="fbContact">联系方式</label>
                    <input type="text" id="fbContact" placeholder="QQ / 邮箱 / 其他（选填）">
                </div>
                <div class="form-group">
                    <label for="fbContent">反馈内容 *</label>
                    <textarea id="fbContent" required placeholder="请详细描述您的问题或建议..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary" id="fbSubmitBtn">
                    <i class="fas fa-paper-plane"></i> 提交反馈
                </button>
            </form>
        </div>
    `;
}

async function submitFeedback(e) {
    e.preventDefault();
    const btn = document.getElementById('fbSubmitBtn');
    if (btn.disabled) return;

    const feedback = {
        type: document.getElementById('fbType').value,
        work: document.getElementById('fbWork').value,
        contact: document.getElementById('fbContact').value,
        content: document.getElementById('fbContent').value,
        date: new Date().toISOString(),
    };

    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 提交中...';

    try {
        const cfg = AppState.config;
        const ok = await submitFeedbackToGitHub(feedback, cfg);
        if (ok) {
            showToast('✅ 反馈已成功提交，感谢您的支持！', 'success');
            document.getElementById('feedbackForm').reset();
        }
    } catch (err) {
        showToast('❌ 提交失败: ' + err.message, 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-paper-plane"></i> 提交反馈';
    }
}

