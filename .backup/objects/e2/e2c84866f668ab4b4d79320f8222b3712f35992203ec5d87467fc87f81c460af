// ---------- 管理功能函数 ----------

function adminLogin() {
    const pwd = document.getElementById('adminPwd')?.value || '';
    const cfg = AppState.config;
    if (cfg && cfg.admin && cfg.admin.password && pwd === cfg.admin.password) {
        AppState.adminLoggedIn = true;
        showToast('✅ 登录成功', 'success');
        renderPage();
    } else {
        showToast('❌ 密码错误，请重试', 'error');
    }
}

function adminLogout() {
    AppState.adminLoggedIn = false;
    renderPage();
    showToast('已退出管理', 'info');
}

function showWorkModal(id) {
    const modal = document.getElementById('workModal');
    if (!modal) return;

    if (id) {
        // 编辑模式
        const work = AppState.works.find(w => w.id === id);
        if (!work) return;
        document.getElementById('modalTitle').textContent = '编辑作品';
        document.getElementById('workId').value = work.id;
        document.getElementById('workTitle').value = work.title || '';
        document.getElementById('workCover').value = work.cover || '';
        document.getElementById('workSummary').value = work.summary || '';
        document.getElementById('workTags').value = (work.tags || []).join(', ');
        document.getElementById('workDate').value = work.date || '';
        document.getElementById('workStatus').value = work.status || '已发布';
        document.getElementById('workContent').value = work.content || '';
    } else {
        // 添加模式
        document.getElementById('modalTitle').textContent = '添加作品';
        document.getElementById('workId').value = '';
        document.getElementById('workTitle').value = '';
        document.getElementById('workCover').value = '';
        document.getElementById('workSummary').value = '';
        document.getElementById('workTags').value = '';
        document.getElementById('workDate').value = fmtDate(new Date());
        document.getElementById('workStatus').value = '已发布';
        document.getElementById('workContent').value = '';
    }

    modal.classList.add('active');
}

function closeWorkModal() {
    document.getElementById('workModal')?.classList.remove('active');
}

function saveWork(e) {
    e.preventDefault();
    const id = document.getElementById('workId').value;
    const title = document.getElementById('workTitle').value.trim();
    if (!title) {
        showToast('请输入作品标题', 'error');
        return;
    }

    const tags = document.getElementById('workTags').value
        .split(/[,，]/)
        .map(t => t.trim())
        .filter(t => t);

    const workData = {
        id: id || genId(),
        title: title,
        cover: document.getElementById('workCover').value.trim() || '',
        summary: document.getElementById('workSummary').value.trim() || '',
        tags: tags,
        date: document.getElementById('workDate').value || fmtDate(new Date()),
        status: document.getElementById('workStatus').value,
        content: document.getElementById('workContent').value,
    };

    if (id) {
        // 编辑：替换原有
        const idx = AppState.works.findIndex(w => w.id === id);
        if (idx >= 0) AppState.works[idx] = workData;
    } else {
        // 添加
        AppState.works.push(workData);
    }

    // 持久化保存到本地
    saveWorksToLocal();
    closeWorkModal();
    showToast('✅ 作品已保存', 'success');
    // 重新渲染管理面板
    renderPage();
}

function deleteWork(id) {
    if (!confirm('确定要删除该作品吗？此操作不可撤销。')) return;
    AppState.works = AppState.works.filter(w => w.id !== id);
    saveWorksToLocal();
    showToast('🗑️ 作品已删除', 'info');
    renderPage();
}

/** 将作品数据保存到本地 JSON 文件（触发浏览器下载，供部署者替换）*/
function saveWorksToLocal() {
    downloadJSON(AppState.works, 'works.json');
    // 同时也显示提醒
    showToast('💾 请将下载的 works.json 替换到 /data/ 目录', 'info');
}

/** 导出配置 */
function downloadConfig() {
    const config = AppState.config;
    if (config) {
        downloadJSON(config, 'config.json');
        showToast('✅ 配置已导出', 'success');
    }
}

/** 将 works.json 提交到 GitHub 仓库 */
async function syncToGitHub() {
    const gh = AppState.config?.github;
    if (!gh || !gh.owner || !gh.repo || !gh.token) {
        showToast('请先在 /data/config.json 中配置 GitHub Token', 'error');
        return;
    }

    showToast('🔄 正在同步到 GitHub...', 'info');
    try {
        const content = btoa(unescape(encodeURIComponent(JSON.stringify(AppState.works, null, 2))));
        const apiUrl = `https://api.github.com/repos/${gh.owner}/${gh.repo}/contents/data/works.json`;

        // 先尝试获取现有文件的 sha
        let sha = '';
        try {
            const existing = await fetchJSON(apiUrl, {
                headers: {
                    'Authorization': `token ${gh.token}`,
                    'Accept': 'application/vnd.github.v3+json'
                }
            });
            sha = existing.sha;
        } catch (e) {
            // 文件可能不存在，忽略
        }

        const body = {
            message: `Update works.json - ${new Date().toISOString().slice(0,10)}`,
            content: content,
            branch: 'main'
        };
        if (sha) body.sha = sha;

        await fetchJSON(apiUrl, {
            method: 'PUT',
            headers: {
                'Authorization': `token ${gh.token}`,
                'Content-Type': 'application/json',
                'Accept': 'application/vnd.github.v3+json'
            },
            body: JSON.stringify(body)
        });

        showToast('✅ 同步成功！works.json 已更新到 GitHub', 'success');
    } catch (e) {
        showToast('❌ 同步失败: ' + e.message, 'error');
    }
}

// ==================== 初始化 ====================

async function init() {
    try {
        // 加载配置
        const config = await loadJSON('config.json');
        if (!config) {
            // 如果加载失败，设置默认配置
            AppState.config = {
                siteTitle: '汉化资源站',
                siteSubtitle: '用心汉化，分享快乐',
                about: {
                    avatar: '',
                    name: '汉化作者',
                    bio: '个人汉化者',
                    content: '## 欢迎\n\n内容正在编辑中...'
                },
                social: [],
                admin: { password: 'admin123' },
                github: { owner: '', repo: '', token: '' }
            };
        } else {
            AppState.config = config;
        }

        // 设置站点标题
        if (AppState.config.siteTitle) {
            document.getElementById('siteTitle').textContent = AppState.config.siteTitle;
            document.title = AppState.config.siteTitle;
        }

        // 加载作品数据
        const works = await loadJSON('works.json');
        if (works && Array.isArray(works)) {
            AppState.works = works;
        } else {
            AppState.works = [];
        }

        // 处理 hash 路由
        if (window.location.hash) {
            handleHashChange();
        } else {
            renderPage();
        }

        // 监听 hash 变化
        window.addEventListener('hashchange', handleHashChange);

        console.log(`[Init] 站点已加载，共 ${AppState.works.length} 个作品`);
    } catch (e) {
        console.error('[Init] 初始化失败:', e);
        document.getElementById('mainContent').innerHTML = `
            <div style="text-align:center;padding:80px 20px;">
                <h2>😵 加载失败</h2>
                <p style="color:var(--text-secondary);margin:16px 0;">${escHtml(e.message)}</p>
                <button class="btn btn-primary" onclick="location.reload()">重新加载</button>
            </div>
        `;
    }
}

