                <h1 class="work-detail-title">${escHtml(work.title || '')}</h1>
                <div class="work-detail-meta">
                    ${tags}
                    <span class="work-detail-status" style="background:${work.status === '已下架' ? '#fee2e2' : '#dcfce7'};color:${work.status === '已下架' ? '#dc2626' : '#16a34a'}">
                        ${escHtml(work.status || '未知')}
                    </span>
                    <span class="work-detail-date">📅 ${work.date || ''}</span>
                </div>
            </div>
            ${coverHtml}
            <div class="work-detail-content markdown-body">
                ${renderMarkdown(work.content || '暂无内容')}
            </div>
