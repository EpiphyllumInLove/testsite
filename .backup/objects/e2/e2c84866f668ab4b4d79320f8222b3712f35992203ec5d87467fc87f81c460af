/**
 * 汉化资源站 - 主应用脚本 (SPA)
 * 基于纯前端 + GitHub API，数据存储在 /data/ 目录
 * 支持：介绍页 / 作品列表 / 作品详情 / 反馈 / 管理面板
 */
'use strict';

// ==================== 全局状态 ====================
const AppState = {
    config: null,        // site config
    works: [],           // works list
    currentPage: 'home', // home | works | work-detail | feedback | admin
    currentWork: null,   // 当前查看的作品
    adminLoggedIn: false,
    searchQuery: '',
};

// ==================== 页面基础路径 ====================
const BASE_PATH = window.location.origin + window.location.pathname.replace(/\/+$/, '');
const DATA_PATH = 'data';

// ==================== 工具函数 ====================

/** 显示 Toast 通知 */
function showToast(msg, type = 'info') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast ' + type + ' show';
    clearTimeout(t._hideTimer);
    t._hideTimer = setTimeout(() => t.classList.remove('show'), 3000);
}

/** 统一 fetch 封装 (带超时) */
async function fetchJSON(url, options = {}) {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 15000);
    try {
        const res = await fetch(url, { ...options, signal: controller.signal });
        clearTimeout(timeout);
        if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
        return await res.json();
    } catch (e) {
        clearTimeout(timeout);
        throw e;
    }
}

/** 生成唯一 ID */
function genId() {
    return 'w-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 7);
}

/** 格式化日期 yyyy-MM-dd */
function fmtDate(d) {
    const dt = new Date(d);
    return dt.getFullYear() + '-' +
        String(dt.getMonth()+1).padStart(2,'0') + '-' +
        String(dt.getDate()).padStart(2,'0');
}

/** HTML转义 */
function escHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

/** 安全渲染 Markdown，返回 HTML */
function renderMarkdown(md) {
    if (!md) return '';
    try {
        return marked.parse(md, { breaks: true, gfm: true });
    } catch (e) {
        return '<p>' + escHtml(md) + '</p>';
    }
}

/** 获取社交图标的 FontAwesome 类名 */
function getSocialIcon(name) {
    const map = {
        'weibo': 'fab fa-weibo',
        'bilibili': 'fab fa-bilibili',
        'twitter': 'fab fa-twitter',
        'github': 'fab fa-github',
        'qq': 'fab fa-qq',
        'wechat': 'fab fa-weixin',
        'telegram': 'fab fa-telegram',
        'discord': 'fab fa-discord',
        'email': 'fas fa-envelope',
        'youtube': 'fab fa-youtube',
        'bilibili': 'fas fa-tv',
    };
    return map[name.toLowerCase()] || 'fas fa-link';
}

// ==================== 数据加载与持久化 ====================

/** 从 /data/ 目录加载 JSON 文件（采用 try-catch，加载失败则使用默认值） */
async function loadJSON(file) {
    try {
        const resp = await fetch(`${DATA_PATH}/${file}?_t=${Date.now()}`);
        if (resp.ok) return await resp.json();
        throw new Error('File not found');
    } catch (e) {
        console.warn(`[loadJSON] Failed to load ${file}:`, e.message);
        return null;
    }
}

/** 保存数据到本地 —— 通过下载方式（用户需手动覆盖 data 目录下的文件）*/
function downloadJSON(data, filename) {
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
}

/**
 * GitHub API：提交反馈到仓库的 issues 或 feedback 文件
 */
async function submitFeedbackToGitHub(feedback, config) {
    const gh = config.github;
    if (!gh || !gh.owner || !gh.repo || !gh.token) {
        // 如果没有配置 GitHub，则降级为下载 JSON 文件
        downloadJSON({ feedbacks: [feedback] }, `feedback-${Date.now()}.json`);
        return true;
    }

    // 用 GitHub API 在仓库中创建一个 issue，或追加到 feedbacks.json
    // 此处采用 Append 到 feedbacks.json 的方案（需要先读取再更新，简单起见用 issues）
    // 方案1：创建 Issue（无需读取已有数据）
    try {
        const body = [
            `## 反馈详情`,
            `**类型**: ${feedback.type}`,
            `**作品**: ${feedback.work || '无'}`,
            `**联系**: ${feedback.contact || '未留'}`,
            `**内容**:`,
            feedback.content,
            `---`,
            `*提交时间: ${feedback.date}*`,
            `*用户代理: ${navigator.userAgent}*`
        ].join('\n');

        await fetchJSON(`https://api.github.com/repos/${gh.owner}/${gh.repo}/issues`, {
            method: 'POST',
            headers: {
                'Authorization': `token ${gh.token}`,
                'Content-Type': 'application/json',
                'Accept': 'application/vnd.github.v3+json'
            },
            body: JSON.stringify({
                title: `[反馈] ${feedback.type} - ${feedback.work || '其他'}`,
                body: body,
                labels: ['feedback', feedback.type]
            })
        });
        return true;
    } catch (e) {
        console.error('[GitHub] Issue 提交失败:', e);
        // 降级下载
        downloadJSON({ feedback: feedback }, `feedback-${Date.now()}.json`);
        return true; // 虽降级但仍算成功
    }
}

// ==================== SPA 路由 ====================

function navigateTo(page, param) {
    // 关闭移动菜单
    document.getElementById('navMenu').classList.remove('active');

    // 更新导航高亮
    document.querySelectorAll('.nav-link').forEach(el => {
        el.classList.toggle('active', el.dataset.page === page);
    });

    AppState.currentPage = page;
    if (page === 'work-detail') {
        AppState.currentWork = param || null;
    }

    // 更新 URL hash
    let hash = page;
    if (page === 'work-detail' && param) hash += '/' + param;
    window.location.hash = hash;

    renderPage();
}

function toggleMobileMenu() {
    document.getElementById('navMenu').classList.toggle('active');
}

// ==================== 页面路由处理 ====================

function handleHashChange() {
    const hash = window.location.hash.slice(1) || 'home';
    const parts = hash.split('/');
    const page = parts[0];
    const param = parts.slice(1).join('/');

    document.querySelectorAll('.nav-link').forEach(el => {
        el.classList.toggle('active', el.dataset.page === page || (page === 'work-detail' && el.dataset.page === 'works'));
    });

    AppState.currentPage = page;
    if (page === 'work-detail') AppState.currentWork = AppState.works.find(w => w.id === param) || null;

    renderPage();
}

// ==================== 页面渲染 ====================

function renderPage() {
    const main = document.getElementById('mainContent');
    if (!main) return;

    switch (AppState.currentPage) {
        case 'home': renderHome(main); break;
        case 'works': renderWorks(main); break;
        case 'work-detail': renderWorkDetail(main); break;
        case 'feedback': renderFeedback(main); break;
        case 'admin': renderAdmin(main); break;
        default: renderHome(main);
    }

    // 滚动到顶部
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ---------- 介绍页 ----------
function renderHome(main) {
    const cfg = AppState.config;
    if (!cfg) {
        main.innerHTML = '<div class="about-hero"><p>加载中...</p></div>';
        return;
    }

    const about = cfg.about || {};
    const social = cfg.social || [];

    let socialHtml = '';
    if (social.length) {
        socialHtml = `<div class="social-links">${social.map(s =>
            `<a href="${escHtml(s.url)}" target="_blank" rel="noopener" class="social-link">
                <i class="${getSocialIcon(s.icon || s.name)}"></i>
                <span>${escHtml(s.name)}</span>
            </a>`
        ).join('')}</div>`;
    }

    main.innerHTML = `
        <div class="about-hero">
            ${about.avatar ? `<img src="${escHtml(about.avatar)}" alt="avatar" class="about-avatar">` :
                `<div class="about-avatar" style="display:flex;align-items:center;justify-content:center;font-size:3rem;background:var(--border);">👤</div>`}
            <div class="about-name">${escHtml(about.name || '')}</div>
            <div class="about-bio">${escHtml(about.bio || '')}</div>
            ${socialHtml}
        </div>
        <div class="about-content markdown-body">
            ${renderMarkdown(about.content || '## 欢迎\n\n内容正在编辑中...')}
        </div>
    `;
}

// ---------- 作品列表页 ----------
function renderWorks(main) {
    const works = AppState.works || [];
    const query = AppState.searchQuery || '';

    let filtered = works;
    if (query.trim()) {
        const q = query.toLowerCase();
        filtered = works.filter(w =>
            (w.title && w.title.toLowerCase().includes(q)) ||
            (w.summary && w.summary.toLowerCase().includes(q)) ||
            (w.tags && w.tags.some(t => t.toLowerCase().includes(q)))
        );
    }

    // 按日期排序（最新的在前）
    const sorted = [...filtered].sort((a, b) => {
        return (new Date(b.date || 0)) - (new Date(a.date || 0));
    });

    main.innerHTML = `
        <div class="works-header">
            <h1>
                <span>📚 汉化作品</span>
                <span class="works-count">(${sorted.length} 部)</span>
            </h1>
            <div class="works-search">
                <input type="text" id="worksSearch" placeholder="搜索作品标题/标签..." value="${escHtml(query)}" oninput="onWorksSearch(this.value)">
            </div>
        </div>
        <div class="works-grid">
            ${sorted.length === 0 ? '<p style="grid-column:1/-1;text-align:center;color:var(--text-secondary);padding:60px 0;">暂无作品，敬请期待！</p>' :
                sorted.map(w => {
                    const coverStyle = w.cover ? `style="background-image:url(${escHtml(w.cover)});background-size:cover;background-position:center;"` : '';
                    const coverIcon = w.cover ? '' : '🎮';
                    const tags = (w.tags || []).map(t => `<span class="work-card-tag">${escHtml(t)}</span>`).join('');
                    return `
                    <div class="work-card" onclick="navigateTo('work-detail','${escHtml(w.id)}')">
                        <div class="work-card-cover" ${coverStyle}>${coverIcon}</div>
                        <div class="work-card-body">
                            <div class="work-card-title">${escHtml(w.title || '未命名作品')}</div>
                            <div class="work-card-summary">${escHtml(w.summary || '')}</div>
                            <div class="work-card-meta">
                                ${tags}
                                <span class="work-card-date">${w.date || ''}</span>
                            </div>
                        </div>
                    </div>`;
                }).join('')}
        </div>
    `;

    document.getElementById('worksSearch')?.focus();
}

function onWorksSearch(val) {
    AppState.searchQuery = val;
    renderPage();
}

