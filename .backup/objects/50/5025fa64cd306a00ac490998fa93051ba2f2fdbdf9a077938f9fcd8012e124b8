<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>汉化资源站</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <!-- 头部导航 -->
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <div class="nav-brand" onclick="navigateTo('home')">
                    <span class="brand-icon">🎮</span>
                    <span class="brand-text" id="siteTitle">汉化资源站</span>
                </div>
                <div class="nav-toggle" id="navToggle" onclick="toggleMobileMenu()">
                    <i class="fas fa-bars"></i>
                </div>
                <ul class="nav-menu" id="navMenu">
                    <li><a href="#" onclick="navigateTo('home')" class="nav-link active" data-page="home"><i class="fas fa-home"></i> 介绍</a></li>
                    <li><a href="#" onclick="navigateTo('works')" class="nav-link" data-page="works"><i class="fas fa-gamepad"></i> 作品</a></li>
                    <li><a href="#" onclick="navigateTo('feedback')" class="nav-link" data-page="feedback"><i class="fas fa-comment"></i> 反馈</a></li>
                    <li class="nav-admin-link"><a href="#" onclick="navigateTo('admin')" class="nav-link" data-page="admin"><i class="fas fa-cog"></i> 管理</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- 主内容区域 -->
    <main id="mainContent">
        <!-- 页面由JS动态渲染 -->
    </main>

    <!-- 反馈浮动按钮（用于通知） -->
    <div id="toast" class="toast"></div>

    <!-- Markdown 解析库 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/marked/12.0.2/marked.min.js"></script>
    <!-- 主应用 -->
    <script src="js/app.js"></script>
</body>
</html>
